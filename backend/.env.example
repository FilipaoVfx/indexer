PORT=8787
MAX_BATCH_SIZE=50
ALLOWED_ORIGINS=https://your-frontend.example.com,chrome-extension://<your-extension-id>

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# The backend should prefer the service role key so DB-side RLS can stay enabled.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: used by `npm run readmes:github` to avoid unauthenticated GitHub API limits.
GITHUB_TOKEN=your-github-token
GITHUB_README_MAX_PER_BATCH=8
GITHUB_README_MAX_CHARS=300000
GITHUB_README_TTL_HOURS=168
