---
interface Props {
  title?: string;
}
const { title = "Consola de conocimiento" } = Astro.props;
---

<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="astro-base" content={import.meta.env.BASE_URL} />
    <title>{title}</title>
    <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-error-container": "#fecaca",
              "error-container": "#3a0000",
              "on-primary-fixed": "#001a1f",
              "inverse-on-surface": "#0f0f17",
              "on-primary-container": "#cffafe",
              "tertiary-fixed-dim": "#d8b4fe",
              "surface-dim": "#0a0a0f",
              "primary-fixed-dim": "#22d3ee",
              "on-background": "#e4e4f0",
              "on-tertiary-container": "#ede9fe",
              "surface-container": "#12121a",
              "surface-container-high": "#1a1a24",
              "surface-variant": "#1f1f2b",
              "secondary-fixed-dim": "#c084fc",
              "surface-container-low": "#0f0f17",
              "secondary-fixed": "#e9d5ff",
              "on-surface": "#e4e4f0",
              "outline-variant": "#2a2a3a",
              "secondary-container": "#581c87",
              "inverse-surface": "#e4e4f0",
              "on-tertiary": "#0a0a0f",
              "primary-fixed": "#cffafe",
              "on-secondary": "#0a0a0f",
              "surface-tint": "#22d3ee",
              "surface-bright": "#22222f",
              "outline": "#4c4c60",
              "surface-container-lowest": "#08080c",
              "tertiary": "#c084fc",
              "background": "#0a0a0f",
              "inverse-primary": "#0891b2",
              "tertiary-container": "#6b21a8",
              "error": "#ff5370",
              "on-error": "#0a0a0f",
              "primary-container": "#0e7490",
              "secondary": "#a855f7",
              "on-primary": "#0a0a0f",
              "primary": "#22d3ee",
              "surface-container-highest": "#26263a",
              "surface": "#0a0a0f",
              "on-surface-variant": "#9ca3af"
            },
            borderRadius: { none: "0px", DEFAULT: "0px", sm: "0px", md: "0px", lg: "0px", xl: "0px", "2xl": "0px", "3xl": "0px", full: "9999px" },
            fontFamily: { headline: ["JetBrains Mono", "monospace"], body: ["JetBrains Mono", "monospace"], label: ["JetBrains Mono", "monospace"], mono: ["JetBrains Mono", "monospace"] }
          }
        }
      };
    </script>
    <style>
      body { font-family: 'JetBrains Mono', ui-monospace, monospace; }
      .font-headline { font-family: 'JetBrains Mono', ui-monospace, monospace; letter-spacing: -0.02em; }
      .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24; }

      /* Neobrutalist primitives */
      .neo-shadow { box-shadow: 4px 4px 0 0 #22d3ee; }
      .neo-shadow-sm { box-shadow: 2px 2px 0 0 #22d3ee; }
      .neo-shadow-purple { box-shadow: 4px 4px 0 0 #a855f7; }
      .neo-shadow-purple-sm { box-shadow: 2px 2px 0 0 #a855f7; }
      .neo-shadow-black { box-shadow: 4px 4px 0 0 #000000; }
      .terminal-panel { background: #0f0f17; border: 2px solid #22d3ee; }
      .terminal-card { background: #12121a; border: 2px solid #2a2a3a; }
      .terminal-card:hover { border-color: #22d3ee; }

      /* Arch terminal-style scrollbars */
      ::-webkit-scrollbar { width: 10px; height: 10px; }
      ::-webkit-scrollbar-track { background: #0a0a0f; }
      ::-webkit-scrollbar-thumb { background: #22d3ee; border: 2px solid #0a0a0f; }
      ::-webkit-scrollbar-thumb:hover { background: #a855f7; }

      /* Glass aliases -> neobrutalist panels (keeps legacy class usage working) */
      .glass-panel { background: #0f0f17; border: 2px solid #22d3ee; box-shadow: 4px 4px 0 0 #22d3ee; }
      .glass-card { background: #12121a; border: 2px solid #2a2a3a; transition: border-color .15s, box-shadow .15s; }
      .glass-card:hover { border-color: #a855f7; box-shadow: 4px 4px 0 0 #a855f7; transform: translate(-2px, -2px); }
      .bubble-glow { box-shadow: 4px 4px 0 0 #22d3ee; }

      /* Selection + highlight */
      ::selection { background: #22d3ee; color: #0a0a0f; }
      mark { background: #a855f7; color: #0a0a0f; padding: 0 2px; font-weight: 700; }

      /* Terminal prompt helpers */
      .prompt-caret::before { content: "$"; color: #22d3ee; font-weight: 700; margin-right: 0.5rem; }
      .prompt-arch::before { content: "[user@arch ~]"; color: #a855f7; font-weight: 700; margin-right: 0.5rem; }
      .caret-blink::after { content: "_"; color: #22d3ee; animation: caret-blink 1s steps(2, start) infinite; margin-left: 2px; }
      @keyframes caret-blink { to { visibility: hidden; } }

      .no-scrollbar::-webkit-scrollbar { display: none; }
      .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .line-clamp-4 { display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
      .line-clamp-6 { display: -webkit-box; -webkit-line-clamp: 6; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
  </head>
  <body class="bg-background text-on-surface selection:bg-primary selection:text-on-primary">
    <slot />
  </body>
</html>
