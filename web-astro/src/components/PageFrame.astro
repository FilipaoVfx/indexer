---
import Layout from "./Layout.astro";
import MobileNav from "./MobileNav.astro";
import Sidebar from "./Sidebar";

interface Props {
  current?: "all" | "recent" | "media" | "links" | "authors" | "repos";
  title?: string;
}

const { current = "all", title = "Consola de conocimiento" } = Astro.props;
---

<Layout title={title}>
  <div class="flex h-screen overflow-hidden">
    <Sidebar client:load current={current} />
    <main
      class:list={[
        "flex-1 flex flex-col min-w-0",
        current === "all" ? "overflow-hidden" : "overflow-y-auto",
      ]}
    >
      <slot />
    </main>
  </div>
  <MobileNav current={current} />
</Layout>
